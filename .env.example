# ============================================================
# OpenCode - Variables de entorno
# Copia este archivo a .env y rellena las que necesites
# ============================================================

# ---- GRATUITOS (solo requieren registro) ---- #

# Groq: https://console.groq.com/keys (GRATIS, muy rápido)
# Modelos: Llama 3.3 70B, Llama 3.1 8B, Gemma 2 9B, Mixtral 8x7B, DeepSeek R1, Qwen QwQ 32B
GROQ_API_KEY=

# OpenRouter: https://openrouter.ai/keys (GRATIS para modelos :free)
# Modelos gratis: Qwen3 Coder 480B, GPT-OSS 120B, NVIDIA Nemotron 120B, Gemma 3n, etc.
OPENROUTER_API_KEY=

# Cerebras: https://cloud.cerebras.ai (GRATIS, inferencia ultrarrápida)
# Modelos: Llama 3.3 70B, Qwen3 32B
CEREBRAS_API_KEY=

# Together AI: https://api.together.xyz (créditos gratis al registrarse)
# Modelos gratis: Llama 3.3 70B Turbo Free
TOGETHER_AI_API_KEY=

# ---- DE PAGO (con tiers gratuitos limitados) ---- #

# Anthropic Claude: https://console.anthropic.com
# En Replit se usa automáticamente la integración interna
ANTHROPIC_API_KEY=

# OpenAI: https://platform.openai.com
# En Replit se usa automáticamente la integración interna
OPENAI_API_KEY=

# Google Gemini: https://aistudio.google.com/app/apikey
# En Replit se usa automáticamente la integración interna
GOOGLE_GENERATIVE_AI_API_KEY=

# Mistral AI: https://console.mistral.ai
MISTRAL_API_KEY=

# xAI Grok: https://console.x.ai
XAI_API_KEY=

# Perplexity: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# ---- OLLAMA (modelos locales - 100% gratis) ---- #
# Si tienes Ollama corriendo localmente o en docker-compose
# OLLAMA_HOST=http://localhost:11434

# ---- CONFIGURACIÓN DEL SERVIDOR ---- #
PORT=3000
OPENCODE_WORKSPACE=/workspace
