{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": false,
  "snapshot": true,
  "permission": "allow",
  "model": "anthropic/claude-sonnet-4-5",

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": [
        "node",
        "/home/runner/mcp-tools/node_modules/@modelcontextprotocol/server-filesystem/dist/index.js",
        "/home/runner/workspace",
        "/tmp"
      ]
    },
    "memory": {
      "type": "local",
      "command": [
        "node",
        "/home/runner/mcp-tools/node_modules/@modelcontextprotocol/server-memory/dist/index.js"
      ]
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "node",
        "/home/runner/mcp-tools/node_modules/@modelcontextprotocol/server-sequential-thinking/dist/index.js"
      ]
    },
    "playwright-browser": {
      "type": "local",
      "command": [
        "node",
        "/home/runner/mcp-tools/node_modules/@playwright/mcp/cli.js",
        "--headless"
      ]
    },
    "computer-tools": {
      "type": "local",
      "command": [
        "node",
        "/home/runner/workspace/bin/mcp-computer.mjs"
      ]
    }
  }
}
